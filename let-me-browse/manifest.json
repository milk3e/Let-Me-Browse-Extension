{
  "manifest_version": 3,
  "name": "Let Me Browse",
  "version": "1.0",
  "description": "Removes scroll locks and forced login popups so you can keep browsing.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Let Me Browse"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "letmebrowse@github.io"
    }
  }
}
